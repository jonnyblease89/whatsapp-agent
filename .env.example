ANTHROPIC_API_KEY=your_anthropic_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+441234567890
# Exact URL Twilio is configured to POST inbound messages to (must match the Twilio console
# webhook config exactly — used to verify the X-Twilio-Signature on every inbound request).
TWILIO_WEBHOOK_URL=https://your-region-your-project.cloudfunctions.net/whatsapp-agent
GOOGLE_SHEET_ID=your_google_sheet_id
GARAGE_NAME=CH Autoworks
GARAGE_PHONE=07911 123456
# Bearer token required in the x-inbox-token header for all /inbox-facing API routes
INBOX_SECRET=generate_a_long_random_string
# Separate token for the /test-chat staging endpoint, baked directly into test-web/app.js
# (no login screen). Kept distinct from INBOX_SECRET so a leaked test-page token can't be
# used to read real customer conversations or send messages as the garage.
TEST_CHAT_SECRET=generate_a_different_long_random_string
# Web push keys for inbox notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
# Gmail SMTP for the monthly billing report — requires 2-Step Verification enabled,
# then generate an App Password at myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
